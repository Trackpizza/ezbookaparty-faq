# Copy to .env.local for local dev (this file is committed; .env.local is gitignored).
# Without these, /admin + Firestore reads fall back to empty data locally.

ADMIN_PASSWORD=choose-a-password

# From the Firebase service-account key JSON (Project Settings → Service accounts):
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# base64 of the key JSON's `private_key` value (the admin SDK decodes it):
#   node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
FIREBASE_PRIVATE_KEY_BASE64=base64-encoded-private-key

# Used by the admin save → revalidate hook. Locally this is fine as-is.
NEXT_PUBLIC_APP_URL=http://localhost:3000
